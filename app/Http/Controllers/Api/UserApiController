<?php

namespace App\Http\Controllers\Api;
use App\Http\Controllers\Controller;
use App\Http\Resources\ProjectResource;
use App\Models\Project;
use Illuminate\Http\Request;

class UserApiController extends Controller {
    public function index(Request $r) {
        // Implementa la logica per restituire una lista di utenti
        $users = User::all();
        return response()->json($users);

    }

    public function show($id) {
        // Implementa la logica per restituire i dettagli di un utente specifico
        $user = User::find($id);
        if (!$user) {
            return response()->json(['error' => 'User not found'], 404);
        }
        return response()->json($user);

    }

    public function store(Request $r) {
        // Implementa la logica per creare un nuovo utente
        $validated = $r->validate([
            'name' => 'required|string|max:255',
            'email' => 'required|string|email|max:255|unique:users',
            'password' => 'required|string|min:8',
        ]);
        $user = User::create($validated);
        return response()->json($user, 201);

    }

    public function update(Request $r, $id) {
        // Implementa la logica per aggiornare un utente esistente
        $user = User::find($id);
        if (!$user) {
            return response()->json(['error' => 'User not found'], 404);
        }
        $validated = $r->validate([
            'name' => 'sometimes|string|max:255',
            'email' => 'sometimes|string|email|max:255|unique:users,email,' . $user->id,
            'password' => 'sometimes|string|min:8',
        ]);
        $user->update($validated);
        return response()->json($user);

    }

    public function destroy($id) {
        // Implementa la logica per eliminare un utente
        $user = User::find($id);
        if (!$user) {
            return response()->json(['error' => 'User not found'], 404);
        }
        $user->delete();
        return response()->json(['message' => 'User deleted successfully']);
    }
}